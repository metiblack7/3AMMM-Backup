# JWT secret — use any long random string (keep it secret!)
JWT_SECRET=fd32dc0781572d1eb297fb61c4b983c8f35314e23e44c50b898838d450c43a6a

# JWT expiry
JWT_EXPIRES_IN=30d

# Server port
