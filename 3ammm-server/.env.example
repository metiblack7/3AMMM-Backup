# ─────────────────────────────────────────────────────────────
#  3AMMM Server — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/3ammm?retryWrites=true&w=majority

# JWT secret — use any long random string (keep it secret!)
JWT_SECRET=your_jwt_secret_here

# JWT expiry
JWT_EXPIRES_IN=30d

# Server port
PORT=5000

# App environment
NODE_ENV=development

# CORS (production only — comma-separated origins or *)
CORS_ORIGIN=*

# Google OAuth (for POST /api/auth/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=com.ammm.worship://
