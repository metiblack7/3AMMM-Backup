# ─────────────────────────────────────────────────────────────
#  3AMMM Mobile App — Environment Variables (optional)
#  The app reads API URL from src/lib/env.ts by default.
# ─────────────────────────────────────────────────────────────

# Override API URL for local development (optional)
# For simulators/emulators you can use localhost or 10.0.2.2 (android emulator):
# EXPO_PUBLIC_API_URL=http://localhost:5000
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5000  # Android emulator
# For a physical device, set this to your computer's LAN IP (e.g. http://192.168.1.45:5000)
